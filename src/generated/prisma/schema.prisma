// --- 1. CONFIGURATION ---

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- 2. USER & IDENTITY (Auth & Roles) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(NORMAL)

  // Stripe & Pro Status
  stripeCustomerId String? @unique
  isPro            Boolean @default(false)

  // Relationships
  scores       UserScore[]
  feedback     Feedback[]
  subscription Subscription?
  sessions     Session[]
  accounts     Account[]

  // Multiplayer Relationships
  ownedRooms  Room[]            @relation("RoomOwner")
  joinedRooms RoomParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  NORMAL
  ADMIN
}

// --- 3. THE PHYSICAL LAYER (QR Codes) ---

model JengaBlock {
  id         String @id // The ID encoded in the QR (e.g., "BLOCK-01")
  physicalId Int    @unique // 1 to 54
  category   String // e.g., "Python OOP", "SOLID Principles"

  // This links one QR block to its 6 question variations
  questions Quiz[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- 4. THE DIGITAL LAYER (324 Total Questions) ---

model Quiz {
  id       String   @id @default(cuid())
  question String // The prompt for the user
  options  String[] // Code snippets for the Duolingo-style ordering
  answer   Int[] // Correct sequence of indices (e.g., [0, 2, 1])

  // Sorting & Access Logic
  level     Level
  subIndex  Int // 1 or 2 (to handle the 2-questions-per-level rule)
  isPremium Boolean @default(false)

  // Relationship to the QR Block
  blockId String
  block   JengaBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  attempts UserScore[]
  reports  Feedback[]
  rooms    Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Level {
  ENTRY // Free
  JUNIOR // Pro
  SENIOR // Pro
}

// --- 5. MULTIPLAYER ROOMS (Real-time Lobby) ---

model Room {
  id         String     @id @default(cuid())
  joinCode   String     @unique // 6-digit Invite Code 
  status     RoomStatus @default(WAITING)
  maxPlayers Int        @default(6)

  // The current active question for the room
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  ownerId String
  owner   User   @relation("RoomOwner", fields: [ownerId], references: [id])

  participants RoomParticipant[]

  createdAt DateTime @default(now())
}

model RoomParticipant {
  id     String @id @default(cuid())
  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([roomId, userId])
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
}

// --- 6. GAMEPLAY & BILLING ---

model UserScore {
  id        String   @id @default(cuid())
  score     Int
  timeSpent Int?
  mode      GameMode @default(SOLO)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum GameMode {
  SOLO
  MULTIPLAYER
}

model Subscription {
  id               String   @id @default(cuid())
  status           String
  priceId          String
  currentPeriodEnd DateTime

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model Feedback {
  id      String       @id @default(cuid())
  content String
  type    FeedbackType

  userId String
  user   User   @relation(fields: [userId], references: [id])
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  createdAt DateTime @default(now())
}

enum FeedbackType {
  TYPO
  BUG
  SUGGESTION
}

// --- 7. NEXTAUTH SYSTEM ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
